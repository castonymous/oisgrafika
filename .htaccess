# ============================================
# OIS GRAFIKA - Apache Config FIXED
# Admin, API, Upload, Form submit: aman
# Support URL tanpa .php: /admin/index -> /admin/index.php
# ============================================

RewriteEngine On

DirectoryIndex index.php index.html
Options -Indexes
AddDefaultCharset UTF-8

# ============================================
# SECURITY: Block direct access
# ============================================
RewriteRule ^config/ - [F,L]
RewriteRule ^includes/ - [F,L]

<FilesMatch "\.(sql)$">
    Require all denied
</FilesMatch>

<Files "debug-variasi.log">
    Require all denied
</Files>

# ============================================
# JANGAN GANGGU FILE / FOLDER ASLI
# contoh: css, js, gambar, upload, admin/index.php
# ============================================
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# ============================================
# FIX UTAMA:
# URL tanpa .php otomatis buka file .php kalau file-nya ada
# contoh:
# /produk       -> produk.php
# /admin/index  -> admin/index.php
# /admin/login  -> admin/login.php
# ============================================
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/$1.php -f
RewriteRule ^(.+?)/?$ $1.php [L,QSA]

# ============================================
# PRETTY URL PUBLIC
# ============================================

# Detail produk: /produk/{slug} → detail-produk.php?slug={slug}
RewriteRule ^produk/([a-zA-Z0-9_-]+)/?$ detail-produk.php?slug=$1 [L,QSA]

# Kategori: /kategori/{slug} → produk.php?cat={slug}
RewriteRule ^kategori/([a-zA-Z0-9_-]+)/?$ produk.php?cat=$1 [L,QSA]

# Order: /order/{code} → order-detail.php?code={code}
RewriteRule ^order/([a-zA-Z0-9_-]+)/?$ order-detail.php?code=$1 [L,QSA]

# Tracking: /lacak/{code} → tracking.php?code=$1 [L,QSA]

# ============================================
# ANTI-CACHE buat CSS & JS
# ============================================
<IfModule mod_headers.c>
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate, max-age=0"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>

    Header set X-LiteSpeed-Cache-Control "no-cache"
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
</IfModule>

<IfModule LiteSpeed>
    RewriteRule \.(css|js)$ - [E=Cache-Control:no-cache]
</IfModule>

# ============================================
# Cache gambar
# ============================================
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
</IfModule>

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript
</IfModule>

# ============================================
# 404
# Jangan lempar ke /index.php, nanti semua error balik homepage
# Buat file 404.php kalau belum ada
# ============================================
ErrorDocument 404 /404.php